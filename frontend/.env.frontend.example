# AlphaFX Frontend -- Vite Environment Variables
# Copy to frontend/.env.local and adjust for your environment.
#
# In local dev (npm run dev) leave VITE_API_URL empty.
# The Vite dev server proxies /api/* and /ws/* to http://localhost:8000
# automatically, so you do not need to set this variable at all.
#
# Set it only when the API lives on a different origin, e.g.:
#   VITE_API_URL=https://api.staging.alphafx.com
VITE_API_URL=
