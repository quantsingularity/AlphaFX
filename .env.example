# AlphaFX Django — Environment Variables
# Copy to .env and fill in values

# Django
SECRET_KEY=change-this-to-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Database (PostgreSQL)
DATABASE_URL=postgresql://alphafx:alphafx_secret@localhost:5432/alphafx
DB_PASSWORD=alphafx_secret

# Cache (Redis)
REDIS_URL=redis://localhost:6379/0

# Rate APIs (optional — synthetic fallback used if empty)
EXCHANGERATE_API_KEY=
ALPHA_VANTAGE_KEY=

# Application
CACHE_TTL=60
RISK_FREE_RATE=0.05
